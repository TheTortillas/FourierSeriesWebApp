[
  {
    "id": "S01",
    "type": "trig",
    "description": "f(x)=1 on [-π,π] — all coefficients trivial",
    "input": {
      "segments": [{ "expression": "1", "from": "-%pi", "to": "%pi" }],
      "intVar": "x"
    },
    "expected": {
      "a0": "1",
      "an": "0",
      "bn": "0",
      "w0": "1"
    }
  },
  {
    "id": "S02",
    "type": "trig",
    "description": "f(x)=x on [-π,π] — odd function, only sine coefficients",
    "input": {
      "segments": [{ "expression": "x", "from": "-%pi", "to": "%pi" }],
      "intVar": "x"
    },
    "expected": {
      "a0": "0",
      "an": "0",
      "bn": "2*(-1)^(n+1)/n"
    }
  },
  {
    "id": "S03",
    "type": "trig",
    "description": "f(x)=x² on [-π,π] — even function, only cosine coefficients",
    "input": {
      "segments": [{ "expression": "x^2", "from": "-%pi", "to": "%pi" }],
      "intVar": "x"
    },
    "expected": {
      "a0": "%pi^2/3",
      "an": "4*(-1)^n/n^2",
      "bn": "0"
    }
  },
  {
    "id": "S04",
    "type": "trig",
    "description": "f(x)=sign(x) on [-π,π] — piecewise odd function",
    "input": {
      "segments": [
        { "expression": "-1", "from": "-%pi", "to": "0" },
        { "expression": "1",  "from": "0",    "to": "%pi" }
      ],
      "intVar": "x"
    },
    "expected": {
      "a0": "0",
      "an": "0",
      "bn": "2*(1-(-1)^n)/(%pi*n)"
    }
  },
  {
    "id": "S05",
    "type": "trig",
    "description": "f(x)=x on [-1,1] — period T=2, w0=π",
    "input": {
      "segments": [{ "expression": "x", "from": "-1", "to": "1" }],
      "intVar": "x"
    },
    "expected": {
      "a0": "0",
      "an": "0",
      "bn": "2*(-1)^(n+1)/(%pi*n)",
      "w0": "%pi"
    }
  },
