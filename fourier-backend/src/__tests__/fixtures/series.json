    "description": "f(x)=x on [0,π] — cosine: an=2*((-1)^n-1)/(π*n²), sine: bn=2*(-1)^(n+1)/n",
    "input": {
      "segments": [{ "expression": "x", "from": "0", "to": "%pi" }],
